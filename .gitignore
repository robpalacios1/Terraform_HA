# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Ignore Terraform variable definition files that may contain secrets
*.tfvars
*.tfvars.json

# Ignore override files as they are usually local-only
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI config files
.terraformrc
terraform.rc

# Ignore Terraform plan output files
*.tfplan
*.plan
